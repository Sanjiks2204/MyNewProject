NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://mechzo:mechzo@localhost:5432/mechzo?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (RS256). Generate with: openssl genrsa -out jwt.pem 2048; openssl rsa -in jwt.pem -pubout -out jwt.pub
JWT_PRIVATE_KEY_PATH=./keys/jwt.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt.pub
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# OTP — MSG91
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=MECHZO

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Maps
GOOGLE_MAPS_SERVER_KEY=

# Agora
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Storage (Cloudflare R2 / S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mechzo-dev
R2_PUBLIC_BASE_URL=
